#!/usr/bin/env python3
# wallpaper-ui - GTK4/libadwaita frontend for wallpaper.sh
# Dependencies: python3-gi, gir1.2-gtk-4.0, gir1.2-adw-1

import gi
gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Gtk, Adw, Gdk, Gio, GLib

import os, re, glob, random, threading, subprocess

# Update these to match your setup
SCRIPT        = os.path.expanduser("wallpaper.sh")
WALLPAPER_DIR = os.path.expanduser("~/Pictures/Wallpaper")

SCHEMES = [
    "scheme-tonal-spot", "scheme-vibrant", "scheme-expressive",
    "scheme-fidelity", "scheme-fruit-salad", "scheme-monochrome",
    "scheme-neutral", "scheme-rainbow", "scheme-content",
]

PREFER_OPTS = [
    "saturation", "lightness", "darkness", "value",
    "less-saturation", "closest-to-fallback",
]


def read_var(name, default=""):
    """Read a variable value out of wallpaper.sh."""
    try:
        with open(SCRIPT) as f:
            for line in f:
                m = re.match(rf'^{name}="([^"]*)"', line.strip())
                if m:
                    return m.group(1)
    except Exception:
        pass
    return default


def write_var(name, value):
    """Write a variable value back into wallpaper.sh."""
    try:
        with open(SCRIPT) as f:
            content = f.read()
        content = re.sub(rf'^{name}="[^"]*"', f'{name}="{value}"', content, flags=re.MULTILINE)
        with open(SCRIPT, "w") as f:
            f.write(content)
    except Exception as e:
        print(f"write_var failed: {e}")


def rgba_to_hex(rgba):
    return "#{:02x}{:02x}{:02x}".format(
        int(rgba.red * 255),
        int(rgba.green * 255),
        int(rgba.blue * 255),
    )


class MainWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app)
        self.set_title("Wallpaper")
        self.set_default_size(440, 720)
        self.wallpaper_path = None
        self.mode = "image"  # "image" or "color" - controls what Apply does
        self._setup_css()
        self._build()
        self._load_script_values()

    def _setup_css(self):
        css = Gtk.CssProvider()
        css.load_from_data(b"""
            .preview-placeholder {
                border-radius: 12px;
                background-color: alpha(currentColor, 0.06);
                min-height: 200px;
            }
            .preview-image {
                border-radius: 12px;
            }
            .color-active {
                font-weight: bold;
            }
        """)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

    def _build(self):
        tv = Adw.ToolbarView()
        tv.add_top_bar(Adw.HeaderBar())
        self.toast_overlay = Adw.ToastOverlay()

        scroll = Gtk.ScrolledWindow(vexpand=True)
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        clamp = Adw.Clamp()
        clamp.set_maximum_size(480)

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=20)
        root.set_margin_top(20)
        root.set_margin_bottom(32)
        root.set_margin_start(16)
        root.set_margin_end(16)

        # Image preview with a placeholder shown until something is picked
        self.preview_stack = Gtk.Stack()
        self.preview_stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self.preview_stack.set_transition_duration(150)

        placeholder = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        placeholder.add_css_class("preview-placeholder")
        ph_icon = Gtk.Image.new_from_icon_name("image-x-generic-symbolic")
        ph_icon.set_pixel_size(56)
        ph_icon.set_opacity(0.25)
        ph_icon.set_vexpand(True)
        ph_icon.set_valign(Gtk.Align.CENTER)
        placeholder.append(ph_icon)

        self.preview = Gtk.Picture()
        self.preview.set_size_request(-1, 200)
        self.preview.set_content_fit(Gtk.ContentFit.COVER)
        self.preview.add_css_class("preview-image")

        self.preview_stack.add_named(placeholder, "placeholder")
        self.preview_stack.add_named(self.preview, "image")
        root.append(self.preview_stack)

        # Wallpaper picker
        wg = Adw.PreferencesGroup(title="Wallpaper")

        self.wp_row = Adw.ActionRow(title="Image", subtitle="None selected")
        self.wp_row.set_activatable(False)

        rand_btn = Gtk.Button(label="Random", valign=Gtk.Align.CENTER)
        rand_btn.add_css_class("flat")
        rand_btn.connect("clicked", self._on_random)

        browse_btn = Gtk.Button(label="Browse", valign=Gtk.Align.CENTER)
        browse_btn.add_css_class("flat")
        browse_btn.connect("clicked", self._on_browse)

        self.wp_row.add_suffix(rand_btn)
        self.wp_row.add_suffix(browse_btn)
        wg.add(self.wp_row)
        root.append(wg)

        # Color seed picker - clicking the color button instantly switches to color mode
        cg = Adw.PreferencesGroup(title="Color Seed")

        self.color_row = Adw.ActionRow(
            title="Seed color",
            subtitle="Pick a color to use instead of the wallpaper",
        )

        color_dialog = Gtk.ColorDialog()
        color_dialog.set_with_alpha(False)
        self.color_btn = Gtk.ColorDialogButton(dialog=color_dialog)
        self.color_btn.set_valign(Gtk.Align.CENTER)
        default_rgba = Gdk.RGBA()
        default_rgba.parse("#e91e63")
        self.color_btn.set_rgba(default_rgba)
        # As soon as the user picks a color, switch to color mode immediately
        self.color_btn.connect("notify::rgba", self._on_color_picked)

        self.color_row.add_suffix(self.color_btn)
        cg.add(self.color_row)
        root.append(cg)

        # Matugen settings
        mg = Adw.PreferencesGroup(
            title="Matugen",
            description="Written back to wallpaper.sh on apply",
        )

        self.scheme_row = Adw.ComboRow(title="Scheme")
        self.scheme_row.set_model(Gtk.StringList.new(SCHEMES))
        mg.add(self.scheme_row)

        self.contrast_row = Adw.SpinRow(
            title="Contrast",
            subtitle="-1 min  /  0 default  /  1 max",
        )
        self.contrast_row.set_adjustment(
            Gtk.Adjustment(value=0.5, lower=-1.0, upper=1.0, step_increment=0.1)
        )
        self.contrast_row.set_digits(1)
        mg.add(self.contrast_row)

        self.lightness_row = Adw.SpinRow(
            title="Lightness (dark)",
            subtitle="0 = default, higher = brighter dark mode",
        )
        self.lightness_row.set_adjustment(
            Gtk.Adjustment(value=0.3, lower=0.0, upper=1.0, step_increment=0.1)
        )
        self.lightness_row.set_digits(1)
        mg.add(self.lightness_row)

        self.prefer_row = Adw.ComboRow(
            title="Prefer",
            subtitle="Source color extraction method",
        )
        self.prefer_row.set_model(Gtk.StringList.new(PREFER_OPTS))
        mg.add(self.prefer_row)

        root.append(mg)

        # Single apply button - label reflects current mode
        self.apply_btn = Gtk.Button(label="Apply Wallpaper")
        self.apply_btn.add_css_class("suggested-action")
        self.apply_btn.add_css_class("pill")
        self.apply_btn.set_halign(Gtk.Align.CENTER)
        self.apply_btn.set_size_request(220, -1)
        self.apply_btn.connect("clicked", self._on_apply)
        root.append(self.apply_btn)

        clamp.set_child(root)
        scroll.set_child(clamp)
        self.toast_overlay.set_child(scroll)
        tv.set_content(self.toast_overlay)
        self.set_content(tv)

    def _load_script_values(self):
        """Pull current settings out of wallpaper.sh and populate the UI."""
        scheme = read_var("MATUGEN_SCHEME", "scheme-vibrant")
        if scheme in SCHEMES:
            self.scheme_row.set_selected(SCHEMES.index(scheme))
        try:
            self.contrast_row.set_value(float(read_var("MATUGEN_CONTRAST", "0.5")))
        except ValueError:
            pass
        try:
            self.lightness_row.set_value(float(read_var("MATUGEN_LIGHTNESS", "0.3")))
        except ValueError:
            pass
        prefer = read_var("MATUGEN_PREFER", "saturation")
        if prefer in PREFER_OPTS:
            self.prefer_row.set_selected(PREFER_OPTS.index(prefer))

    def _on_browse(self, _btn):
        filt = Gtk.FileFilter()
        filt.set_name("Images")
        for mime in ("image/jpeg", "image/png", "image/webp"):
            filt.add_mime_type(mime)
        store = Gio.ListStore.new(Gtk.FileFilter)
        store.append(filt)
        d = Gtk.FileDialog()
        d.set_filters(store)
        d.open(self, None, self._on_file_chosen)

    def _on_file_chosen(self, dialog, result):
        try:
            f = dialog.open_finish(result)
            self._set_wallpaper(f.get_path())
        except Exception:
            pass

    def _on_random(self, _btn):
        images = []
        for ext in ("jpg", "jpeg", "png", "webp"):
            images += glob.glob(f"{WALLPAPER_DIR}/**/*.{ext}", recursive=True)
        if images:
            self._set_wallpaper(random.choice(images))
        else:
            self._toast(f"No images found in {WALLPAPER_DIR}")

    def _set_wallpaper(self, path):
        self.wallpaper_path = path
        self.wp_row.set_subtitle(os.path.basename(path))
        self.preview.set_file(Gio.File.new_for_path(path))
        self.preview_stack.set_visible_child_name("image")
        self._set_mode("image")

    def _on_color_picked(self, _btn, _param):
        """Fires the moment the user confirms a color - switch to color mode."""
        self._set_mode("color")

    def _set_mode(self, mode):
        """Update the mode and reflect it in the apply button and color row."""
        self.mode = mode
        if mode == "color":
            hex_color = rgba_to_hex(self.color_btn.get_rgba())
            self.apply_btn.set_label(f"Generate from {hex_color}")
            self.color_row.set_subtitle(f"Active  -  {hex_color}")
            self.color_row.set_title("Seed color")
        else:
            self.apply_btn.set_label("Apply Wallpaper")
            self.color_row.set_subtitle("Pick a color to use instead of the wallpaper")

    def _save_settings(self):
        """Write the current UI values back into wallpaper.sh."""
        write_var("MATUGEN_SCHEME",    SCHEMES[self.scheme_row.get_selected()])
        write_var("MATUGEN_CONTRAST",  f"{self.contrast_row.get_value():.1f}")
        write_var("MATUGEN_LIGHTNESS", f"{self.lightness_row.get_value():.1f}")
        write_var("MATUGEN_PREFER",    PREFER_OPTS[self.prefer_row.get_selected()])

    def _on_apply(self, _btn):
        self._save_settings()

        if self.mode == "color":
            hex_color = rgba_to_hex(self.color_btn.get_rgba())
            self._run_script([SCRIPT, "--color", hex_color])
        else:
            if not self.wallpaper_path:
                self._toast("Pick a wallpaper first")
                return
            self._run_script([SCRIPT, self.wallpaper_path])

    def _run_script(self, cmd):
        """Run wallpaper.sh in a thread so the UI stays responsive."""
        self.apply_btn.set_sensitive(False)
        saved_label = self.apply_btn.get_label()
        self.apply_btn.set_label("Applying...")

        def _run():
            try:
                subprocess.run(cmd, check=True)
                GLib.idle_add(self._done, True, saved_label)
            except subprocess.CalledProcessError:
                GLib.idle_add(self._done, False, saved_label)

        threading.Thread(target=_run, daemon=True).start()

    def _done(self, ok, saved_label):
        self.apply_btn.set_sensitive(True)
        self.apply_btn.set_label(saved_label)
        self._toast("Done" if ok else "Something went wrong - check your terminal")

    def _toast(self, msg):
        self.toast_overlay.add_toast(Adw.Toast.new(msg))


class App(Adw.Application):
    def __init__(self):
        super().__init__(application_id="io.github.wallpaper-ui")

    def do_activate(self):
        MainWindow(self).present()


App().run()
